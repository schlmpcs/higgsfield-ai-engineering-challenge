# Required for memory extraction (LLM-based)
ANTHROPIC_API_KEY=sk-ant-...

# Required for embeddings (vector recall). The service will fall back to
# deterministic hash-based embeddings if missing — recall quality drops sharply.
OPENAI_API_KEY=sk-...

# Optional bearer token for the API. If unset, auth is disabled.
MEMORY_AUTH_TOKEN=

# Models (defaults shown)
EXTRACTION_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
